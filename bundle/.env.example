# OpenFn Lightning Environment Configuration

# ------------------------------------------------------------------------------
# Core Secrets (These will be automatically generated by install.sh if left as default)
# ------------------------------------------------------------------------------
PRIMARY_ENCRYPTION_KEY=your_encryption_key_here
SECRET_KEY_BASE=your_secret_key_base_here
POSTGRES_PASSWORD=postgres

# ------------------------------------------------------------------------------
# Database Settings
# ------------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_DB=lightning_prod

# ------------------------------------------------------------------------------
# App Settings
# ------------------------------------------------------------------------------
MIX_ENV=prod
NODE_ENV=production
URL_SCHEME=http
# Set URL_HOST to the IP or DNS name of the server if known, else localhost
URL_HOST=localhost
URL_PORT=4000

# ------------------------------------------------------------------------------
# Worker Settings
# ------------------------------------------------------------------------------
# Authentication secrets for worker communication
WORKER_SECRET=your_worker_secret_here

# Limits
WORKER_MAX_RUN_MEMORY_MB=1024
WORKER_MAX_RUN_DURATION_SECONDS=300
WORKER_CAPACITY=5

# ------------------------------------------------------------------------------
# Networking / Ports
# ------------------------------------------------------------------------------
# External port to expose Lightning on (Default 80 for production air-gapped web)
LIGHTNING_EXTERNAL_PORT=80
